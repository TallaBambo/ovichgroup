extends base

block content
    <section class="hero" style='background-image:linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url(/img/bg-img/values.webp);'>
        <div class="sloggan">
            <h1>Values</h1>
            <p> Our mission and vision are the foundation for every activity we carry out. <br> A set of core values have been established for the ordinary and extraordinary minds of the Ovichmedia group. These values challenge our mindsets, of the way we work and behave.
            </p>
        </div>
        <a href="#" class="arrow-down" aria-label="Arrow down"><i class="fa-solid fa-chevron-down"></i></a>
    </section>
    <section class="container">
        <div class="mission-container">
            <div class="mission vision-text">
                <div class="mission-text">
                    <div class="mission-text-container">
                        <h1>Excellence.</h1>
                        <p>We are committed to excellence and the accuracy evident in our products and services.</p>
                    </div>
                </div>
                <div class="mission-image">
                    <div class="image-container">
                        <img src="/img/mission1.webp" alt="">
                    </div>
                </div>
            </div>
            <div class="mission">
                <div class="mission-text">
                    <div class="mission-text-container">
                        <h1>Audience.</h1>
                        <p>We place our customers first and are at the heart of our organization. We continue to push ourselves to be able to meet the expectations of the public. We exist because we have an audience.</p>
                    </div>
                </div>
                <div class="mission-image">
                    <div class="image-container">
                        <img src="/img/mission2.webp" alt="">
                    </div>
                </div>
            </div>
            <div class="mission vision-text">
                <div class="mission-text">
                    <div class="mission-text-container">
                        <h1>Creativity.</h1>
                        <p>We think outside the box to give you access to the latest, free and exclusive information with our team of experts who push themselves each day to come up with new ideas to be top the charts.</p>
                    </div>
                </div>
                <div class="mission-image">
                    <div class="image-container">
                        <img src="/img/mission3.webp" alt="">
                    </div>
                </div>
            </div>
        </div>
        <section class="cta">
            <div class="cta_cards-container">
                <div class="cta_card">
                    <a href="#"><i class="fa-solid fa-people-arrows"></i></a>
                    <h1>Teamwork.</h1>
                    <p> We believe in teamwork. We combine our abilities with the best minds to educate, inform, engage, entertain and inspire.
                    </p>
                </div>
                <div class="cta_card">
                    <a href="#"><i class="fa-solid fa-users-gear"></i></a>
                    <h1>Innovation.</h1>
                    <p> We are constantly challenged to invent to produce the highest standard of work you can expect from us.
                    </p>
                </div>
                <div class="cta_card">
                    <a href="#"><i class="fa-solid fa-award"></i></a>
                    <h1>Respect.</h1>
                    <p> We are respectful of each other within our team, as we adhere to professional standards and ethics that form our trustworthiness and foster inclusion.
                    </p>
                </div>
            </div>
        </section>
    </section>